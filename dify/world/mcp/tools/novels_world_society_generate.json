{
  "name": "novels_world_society_generate",
  "title": "世界观生成（领土社会层）",
  "description": "调用 Dify 工作流 novel-world-society-v1：根据六边形领土统计与项目参数生成国家设定与聚落 JSON（不生成地图）。",
  "inputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "project_id": { "type": "string" },
      "generation_mode": { "type": "string", "const": "territory_society" },
      "world_name": { "type": "string" },
      "era": { "type": "string" },
      "atmosphere": { "type": "string" },
      "scale": {
        "type": "string",
        "enum": ["kingdom", "archipelago", "continent", "world", "planet"]
      },
      "climate": {
        "type": "string",
        "enum": ["temperate", "cold", "tropical", "mixed"]
      },
      "city_count": { "type": "string" },
      "include_landmarks": { "type": "string", "enum": ["true", "false"] },
      "seed": { "type": "string" },
      "geological_years_ma": { "type": "string" },
      "territory_json": { "type": "string" },
      "nations_outline_json": { "type": "string" },
      "creative_brief": { "type": "string" }
    },
    "required": [
      "project_id",
      "generation_mode",
      "world_name",
      "era",
      "atmosphere",
      "scale",
      "climate",
      "city_count",
      "include_landmarks",
      "seed",
      "territory_json",
      "nations_outline_json",
      "creative_brief"
    ]
  },
  "outputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "status": { "type": "string", "enum": ["success", "error"] },
      "society_json": { "type": "string" },
      "world_rules": { "type": "string" },
      "nations_json": { "type": "string" },
      "locations_json": { "type": "string" },
      "workflow_version": { "type": "string" },
      "error_message": { "type": "string" }
    },
    "required": ["status"]
  },
  "annotations": { "openWorldHint": true }
}
