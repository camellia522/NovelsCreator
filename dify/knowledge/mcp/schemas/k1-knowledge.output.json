{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "novelscreator.knowledge.k1.output",
  "type": "object",
  "required": ["knowledge_summary", "knowledge"],
  "additionalProperties": false,
  "properties": {
    "knowledge_summary": {
      "type": "string",
      "minLength": 50,
      "description": "150–400 字世界观与核心冲突摘要"
    },
    "knowledge": {
      "type": "object",
      "required": ["world", "characters", "factions", "items"],
      "additionalProperties": false,
      "properties": {
        "world": {
          "type": "object",
          "required": ["title", "rules"],
          "additionalProperties": true,
          "properties": {
            "title": { "type": "string", "minLength": 1 },
            "rules": { "type": "string", "minLength": 80 },
            "genre": { "type": "string" },
            "era": { "type": "string" },
            "scene": { "type": "string" },
            "atmosphere": { "type": "string" },
            "techLevel": { "type": "string" },
            "magicConstraint": { "type": "string" },
            "conflictFocus": { "type": "string" },
            "narrativeStyle": { "type": "string" },
            "socialStructure": { "type": "string" },
            "politicalTone": { "type": "string" },
            "warfareStyle": { "type": "string" },
            "economicBase": { "type": "string" },
            "settingConstraints": { "type": "string" },
            "contentTaboos": { "type": "string" }
          }
        },
        "characters": {
          "type": "array",
          "minItems": 3,
          "maxItems": 12,
          "items": {
            "type": "object",
            "required": ["id", "name", "role"],
            "additionalProperties": true,
            "properties": {
              "id": { "type": "string", "pattern": "^char-\\d{3}$" },
              "name": { "type": "string", "minLength": 1 },
              "role": { "type": "string", "minLength": 2 },
              "traits": {
                "type": "array",
                "items": { "type": "string" }
              },
              "appearance": { "type": "string" },
              "personality": { "type": "string" },
              "notes": { "type": "string" }
            }
          }
        },
        "factions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": {
            "type": "object",
            "required": ["id", "name", "description"],
            "additionalProperties": true,
            "properties": {
              "id": { "type": "string", "pattern": "^faction-\\d{3}$" },
              "name": { "type": "string", "minLength": 1 },
              "description": { "type": "string", "minLength": 20 },
              "goals": { "type": "string" }
            }
          }
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "maxItems": 10,
          "items": {
            "type": "object",
            "required": ["id", "name", "description"],
            "additionalProperties": true,
            "properties": {
              "id": { "type": "string", "pattern": "^item-\\d{3}$" },
              "name": { "type": "string", "minLength": 1 },
              "description": { "type": "string", "minLength": 10 }
            }
          }
        }
      }
    }
  }
}
