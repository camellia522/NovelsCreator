{
  "version": "1.2.0",
  "workflow_id": "novel-chapter-generation-v1.1",
  "workflow_name": "Novel Chapter Generation Pipeline",
  "description": "长篇小说单章生产流水线：P0 → N1 → N2a/N2b → AGG → (RE|CB|N3→N4→N5→END_OK) → PARSE → END",
  "mcp_tool": "novels_chapter_generate",
  "retry_strategy": "plan_b_client_loop",
  "nodes": [
    { "id": "START", "type": "start", "title": "Workflow Inputs" },
    { "id": "P0", "type": "code", "title": "Context Merge", "source": "p0_context_merge.py" },
    { "id": "N1", "type": "llm", "title": "Raw Draft", "jinja": true },
    { "id": "N2a", "type": "llm", "title": "Outline Validate", "structured_output": true, "jinja": true },
    { "id": "N2b", "type": "llm", "title": "Lore Validate", "structured_output": true, "jinja": true },
    { "id": "AGG", "type": "code", "title": "Validation Aggregate", "source": "agg_validation.py" },
    { "id": "IF-ROUTE", "type": "if-else", "branches": ["retry", "circuit_break", "continue"] },
    { "id": "RE", "type": "code", "title": "Retry Handoff", "source": "retry_end.py", "outputs": ["end_outputs"] },
    { "id": "CB", "type": "code", "title": "Circuit Break", "source": "cb_circuit_break.py", "outputs": ["end_outputs"] },
    { "id": "N3", "type": "llm", "title": "Line Edit" },
    { "id": "N4a", "type": "llm", "title": "Novel Body Format" },
    { "id": "IF-VIDEO", "type": "if-else", "branches": ["generic-v1", "platform-x-v1", "configurable-v1"] },
    { "id": "N4b-G", "type": "llm", "title": "Video Script Generic" },
    { "id": "N4b-X", "type": "llm", "title": "Video Script Platform X" },
    { "id": "N4b-C", "type": "llm", "title": "Video Script Configurable" },
    { "id": "N4B-MUX", "type": "code", "title": "Video Branch Merge", "source": "n4b_mux.py" },
    { "id": "N5", "type": "llm", "title": "Memory Patch", "structured_output": true },
    { "id": "END_OK", "type": "code", "title": "Success Output", "source": "end_success.py", "outputs": ["end_outputs"] },
    { "id": "PARSE", "type": "code", "title": "Parse End Outputs", "source": "parse_end_outputs.py" },
    { "id": "END", "type": "end", "title": "Workflow Outputs" }
  ],
  "edges": [
    ["START", "P0"],
    ["P0", "N1"],
    ["N1", "N2a"],
    ["N1", "N2b"],
    ["N2a", "AGG"],
    ["N2b", "AGG"],
    ["AGG", "IF-ROUTE"],
    ["IF-ROUTE", "RE", "retry"],
    ["IF-ROUTE", "CB", "circuit_break"],
    ["IF-ROUTE", "N3", "continue"],
    ["N3", "N4a"],
    ["N3", "IF-VIDEO"],
    ["IF-VIDEO", "N4b-G", "generic-v1"],
    ["IF-VIDEO", "N4b-X", "platform-x-v1"],
    ["IF-VIDEO", "N4b-C", "configurable-v1"],
    ["N4b-G", "N4B-MUX"],
    ["N4b-X", "N4B-MUX"],
    ["N4b-C", "N4B-MUX"],
    ["N4a", "N5"],
    ["N4B-MUX", "N5"],
    ["N5", "END_OK"],
    ["END_OK", "PARSE"],
    ["RE", "PARSE"],
    ["CB", "PARSE"],
    ["PARSE", "END"]
  ],
  "end_output_bindings": {
    "status": "PARSE.status",
    "circuit_break": "PARSE.circuit_break",
    "human_action_required": "PARSE.human_action_required",
    "retry_count": "PARSE.retry_count",
    "novel_body": "PARSE.novel_body",
    "video_script": "PARSE.video_script",
    "draft_text": "PARSE.draft_text",
    "retry_issues_formatted": "PARSE.retry_issues_formatted",
    "memory_patch": "PARSE.memory_patch",
    "validation_report": "PARSE.validation_report",
    "workflow_version": "PARSE.workflow_version"
  },
  "prompt_version": "2.0",
  "schema_refs": {
    "input": "novelscreator://dify/schemas/novel-chapter-generate.input/v1.1",
    "output": "novelscreator://dify/schemas/novel-chapter-generate.output/v1.1"
  }
}
