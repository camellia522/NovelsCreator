{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "novelscreator.outline.o1.output",
  "type": "object",
  "required": ["outline_summary", "outline"],
  "additionalProperties": false,
  "properties": {
    "outline_summary": {
      "type": "string",
      "description": "200-500 字全书总纲"
    },
    "outline": {
      "type": "object",
      "required": ["volumes"],
      "additionalProperties": false,
      "properties": {
        "volumes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "title", "chapters"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string", "pattern": "^vol-\\d{2}$" },
              "title": { "type": "string" },
              "chapters": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["id", "title", "status", "beats"],
                  "additionalProperties": false,
                  "properties": {
                    "id": { "type": "string", "pattern": "^ch-\\d{3}$" },
                    "title": { "type": "string" },
                    "status": { "type": "string", "enum": ["draft", "generating", "generated", "published"] },
                    "beats": {
                      "type": "array",
                      "minItems": 2,
                      "maxItems": 12,
                      "items": {
                        "type": "object",
                        "required": ["order", "text"],
                        "additionalProperties": false,
                        "properties": {
                          "order": { "type": "integer", "minimum": 1 },
                          "text": { "type": "string", "minLength": 8 }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
