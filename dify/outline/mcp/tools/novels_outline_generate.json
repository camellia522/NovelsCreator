{
  "name": "novels_outline_generate",
  "title": "生成全书大纲",
  "description": "调用 Dify 工作流 novel-outline-generation-v1：O1 生成 outline.json → O2 结构校验 → 可选重试。",
  "inputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "project_id": { "type": "string", "format": "uuid" },
      "knowledge_snapshot": { "type": "string" },
      "plot_memory": { "type": "string", "default": "{}" },
      "outline_brief": { "type": "string", "default": "" },
      "target_volumes": { "type": "string", "default": "1" },
      "target_chapters": { "type": "string", "default": "12" },
      "genre": { "type": "string", "default": "" },
      "tone": { "type": "string", "default": "" },
      "max_retry": { "type": "string", "default": "3" },
      "retry_count": { "type": "string", "default": "0" },
      "retry_issues_formatted": { "type": "string", "default": "" }
    },
    "required": ["project_id", "knowledge_snapshot", "target_chapters"]
  },
  "outputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "status": { "type": "string", "enum": ["success", "retry", "circuit_break", "error"] },
      "outline_summary": { "type": "string" },
      "outline_json": { "type": "string" },
      "validation_report": { "type": "string" },
      "retry_count": { "type": "integer" },
      "retry_issues_formatted": { "type": "string" },
      "workflow_version": { "type": "string" }
    },
    "required": ["status"]
  },
  "annotations": { "openWorldHint": true }
}
